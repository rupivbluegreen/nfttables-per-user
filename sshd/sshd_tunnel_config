# sshd_tunnel_config — dedicated tunnel-only OpenSSH daemon on port 2222.
# Runs alongside the primary (BoKS-managed) sshd on port 22.
# RHEL 9: allow the port in SELinux first:
#   semanage port -a -t ssh_port_t -p tcp 2222
Port 2222
PidFile /run/sshd_tunnel.pid
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

# Authentication: public key only. Keys live in a root-owned directory so AD
# users need no pre-existing home directory and cannot self-manage keys.
PubkeyAuthentication yes
PasswordAuthentication no
KbdInteractiveAuthentication no
PermitRootLogin no
AuthorizedKeysFile /etc/ssh/tunnel_keys/%u
StrictModes yes
# This daemon uses its own PAM service name "sshd-tunnel" (-> /etc/pam.d/sshd-tunnel),
# set up by sshd-tunnel-setup.sh: a PAMServiceName directive on OpenSSH >= 9.8, or
# running as the /usr/sbin/sshd-tunnel symlink on <= 9.7. That stack contains no
# pam_boks, so port 2222 stays independent of the BoKS-managed sshd on port 22.
UsePAM yes

# Scope: only members of the umbrella tunnel group may connect at all.
AllowGroups tunnel-users

# Tunnel-only: no shells, no listeners, nothing but -L/-D forwards.
# Clients must connect with `ssh -N`.
PermitTTY no
ForceCommand /bin/false
X11Forwarding no
AllowAgentForwarding no
PermitTunnel no
GatewayPorts no
PermitListen none
AllowTcpForwarding yes
ClientAliveInterval 60
ClientAliveCountMax 3

# Per-group destination policy, generated by:
#   tunnelfw.sh sshd-snippet > /etc/ssh/sshd_tunnel_config.d/50-groups.conf
Include /etc/ssh/sshd_tunnel_config.d/*.conf
